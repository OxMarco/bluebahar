NODE_ENV=
PORT=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
REDIS_HOST=
REDIS_PORT=
OPENAI_API_KEY=
# Model used for Notice-to-Mariners AI enrichment (category + summary; never
# touches coordinates). Optional — defaults to gpt-5.5. ENRICH_MODEL overrides
# just enrichment if you want a cheaper model there.
OPENAI_MODEL=
ENRICH_MODEL=
# Vision cross-check of extracted geometry against the notice's chart pages.
# A mismatch only flags the record for manual review; the model never produces
# coordinates. Defaults to true (one extra image-bearing model call per
# geometry notice); set to false to disable. VISION_MODEL must be a multimodal
# model — falls back to ENRICH_MODEL/OPENAI_MODEL/gpt-5.5 when unset.
VISION_VERIFY=
VISION_MODEL=
ADMIN_API_KEY=
ADMIN_JWT_SECRET=
ADMIN_SESSION_TTL_SECONDS=
THROTTLE_TTL_MS=
THROTTLE_LIMIT=
NOTICE_SCRAPE_BATCH_SIZE=
# Egress proxy for the Transport Malta scraper (their Cloudflare WAF 403s
# datacenter IPs). Leave blank for a direct connection. In prod compose this
# defaults to the WARP sidecar (socks5h://warp:1080); set here to override
# with a residential proxy, e.g. socks5h://user:pass@host:port. Must be
# socks5h:// (remote DNS), not socks5://.
SCRAPER_PROXY_URL=
DOMAIN=
ACME_EMAIL=
SENTRY_DSN=
# Fraction (0–1) of transactions/profiles sampled. Default 0.1 if unset.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
# Deploy identifier, set by CI to the git SHA. Tags every event and MUST match
# the value passed to `npm run sentry:sourcemaps` so uploaded source maps line
# up with the running build.
SENTRY_RELEASE=
# Secret org token (sntrys_…) used ONLY at build time by sentry-cli to upload
# source maps. Not needed at runtime. Org/project live in .sentryclirc.
SENTRY_AUTH_TOKEN=
