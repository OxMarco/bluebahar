NODE_ENV=
PORT=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
REDIS_HOST=
REDIS_PORT=
# Required: the community-map import generates every zone description with the LLM.
OPENAI_API_KEY=
# Optional model used to write map-zone descriptions. Defaults to gpt-5.5.
OPENAI_MODEL=
ENRICH_MODEL=
# "Malta Ranger Unit" My Map id — the daily import pulls its marine
# layers as the authoritative source of zone geometry + classification. Leave
# blank to use the built-in default id. Set COMMUNITY_MAP_IMPORT_ENABLED=false to
# disable the import entirely (defaults to true).
COMMUNITY_MAP_MID=
COMMUNITY_MAP_IMPORT_ENABLED=
# Bathing-water classification import (EHD weekly "Site Classification Update
# Report" PDF, merged onto the beaches layer by Site_Code). Defaults true; the
# EHD site sits behind Cloudflare but the importer fetches via impit (browser
# fingerprint impersonation). Source page and parse model are hardcoded; this
# flag is the only knob. Set to false to disable.
BATHING_CLASSIFICATION_IMPORT_ENABLED=
ADMIN_API_KEY=
ADMIN_JWT_SECRET=
ADMIN_SESSION_TTL_SECONDS=
THROTTLE_TTL_MS=
THROTTLE_LIMIT=
DOMAIN=
ACME_EMAIL=
SENTRY_DSN=
# Fraction (0–1) of transactions/profiles sampled. Default 0.1 if unset.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
# Deploy identifier, set by CI to the git SHA. Tags every event and MUST match
# the value passed to `npm run sentry:sourcemaps` so uploaded source maps line
# up with the running build.
SENTRY_RELEASE=
# Secret org token (sntrys_…) used ONLY at build time by sentry-cli to upload
# source maps. Not needed at runtime. Org/project live in .sentryclirc.
SENTRY_AUTH_TOKEN=
