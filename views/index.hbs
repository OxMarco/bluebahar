    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Montserrat:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet" />
  </noscript>

  <style>
    :root {
      --ink: #152051;
      --sky: #78C3EA;
      --paper: #FEFEFE;
    }

    * {
      box-sizing: border-box;
    }

    html {
      min-height: 100%;
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      min-height: 100svh;
      overflow-x: hidden;
      color: var(--ink);
      background-color: var(--sky);
      background-image:
        radial-gradient(circle at 22% 14%, rgba(254, 254, 254, 0.45) 0, rgba(254, 254, 254, 0) 28%),
        radial-gradient(circle at 82% 76%, rgba(21, 32, 81, 0.10) 0, rgba(21, 32, 81, 0) 30%),
        radial-gradient(circle, rgba(21, 32, 81, 0.055) 0.5px, transparent 0.6px);
      background-size: auto, auto, 6px 6px;
      font-family: 'Roboto', sans-serif;
      text-rendering: geometricPrecision;
      -webkit-font-smoothing: antialiased;
    }

    img,
    svg {
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(135deg, rgba(254, 254, 254, 0.25), rgba(254, 254, 254, 0) 36%),
        linear-gradient(to bottom, rgba(120, 195, 234, 0.24), rgba(21, 32, 81, 0.10));
    }

    .landing {
      position: relative;
      isolation: isolate;
      min-height: 100vh;
      min-height: 100svh;
      width: 100%;
      overflow: hidden;
      padding: 1.5rem 1.25rem;
    }

    .map-glass,
    .map-wrap {
      position: absolute;
      inset: 0;
    }

    .map-wrap {
      opacity: 0.95;
      transform: translateY(-3%) scale(1.06);
    }

    .map-svg {
      width: 100%;
      height: 100%;
    }

    .map-fade {
      position: absolute;
      z-index: 0;
      inset-block: 0;
      left: 0;
      width: 100%;
      background: linear-gradient(
        to bottom,
        rgba(120, 195, 234, 0.10),
        rgba(120, 195, 234, 0.34),
        rgba(120, 195, 234, 0.48)
      );
    }

    .page-shell {
      position: relative;
      z-index: 10;
      display: flex;
      min-height: calc(100svh - 3rem);
      max-width: 80rem;
      margin-inline: auto;
      flex-direction: column;
    }

    .brand-header {
      display: flex;
      align-items: center;
      padding-top: 0.5rem;
    }

    .logo {
      width: 4rem;
      height: 4rem;
      flex-shrink: 0;
      padding: 0.375rem;
      user-select: none;
      border-radius: 1.15rem;
      background: rgba(254, 254, 254, 0.20);
      box-shadow:
        0 18px 50px -28px rgba(255, 255, 255, 0.95),
        0 0 0 1px rgba(254, 254, 254, 0.35);
    }

    .brand-wordmark {
      margin-left: 1rem;
      color: rgba(254, 254, 254, 1);
      font-family: 'Fredoka', sans-serif;
      font-weight: 600;
      font-size: clamp(1.5rem, 1rem + 2.5vw, 2.25rem);
      line-height: 1;
      letter-spacing: -0.035em;
      filter: drop-shadow(0 1px 1px rgba(21, 32, 81, 0.16));
      user-select: none;
    }

    .version {
      color: rgba(254, 254, 254, 0.75);
      font-size: 0.875rem;
      font-weight: 400;
    }

    .hero {
      display: flex;
      flex: 1;
      align-items: flex-end;
      padding-block: 4rem 2rem;
    }

    .hero-panel {
      width: 100%;
      max-width: 610px;
    }

    .hero-title {
      max-width: 14ch;
      margin: 0;
      color: var(--ink);
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: clamp(1.875rem, 1rem + 3.25vw, 4rem);
      line-height: 1;
      letter-spacing: -0.04em;
      text-wrap: balance;
    }

    .hero-title-accent {
      display: block;
      color: var(--paper);
      filter: drop-shadow(0 1px 1px rgba(21, 32, 81, 0.16));
    }

    .hero-copy {
      max-width: 42ch;
      margin: 1.5rem 0 0;
      color: rgba(21, 32, 81, 0.75);
      font-size: clamp(1rem, 0.92rem + 0.35vw, 1.1rem);
      line-height: 1.65;
      text-wrap: pretty;
    }

    @keyframes pulse-dot {
      0%, 100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.84;
        transform: scale(1.04);
      }
    }

    .dot-pulse {
      animation: pulse-dot 3.6s ease-in-out infinite;
      transform-origin: center;
      transform-box: fill-box;
    }

    @keyframes ping {
      0% {
        transform: scale(1);
        opacity: 0.58;
      }

      70% {
        opacity: 0;
      }

      100% {
        transform: scale(3.6);
        opacity: 0;
      }
    }

    .dot-ring {
      fill: none;
      stroke-width: 1.5;
      transform-origin: center;
      transform-box: fill-box;
      animation: ping 3s ease-out infinite;
    }

    .accent-line {
      width: clamp(48px, 10vw, 100px);
      height: 3px;
      margin-top: 1.75rem;
      border-radius: 999px;
      background: linear-gradient(90deg, #152051 0%, rgba(21, 32, 81, 0.28) 100%);
    }

    .store-grid {
      display: grid;
      width: 100%;
      max-width: 390px;
      margin-top: 2rem;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.75rem;
    }

    .store-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      min-height: 54px;
      padding: 0.625rem 0.875rem;
      border-radius: 13px;
      background: #050505;
      color: #fff;
      font-family: 'Montserrat', sans-serif;
      box-shadow: 0 16px 34px -20px rgba(21, 32, 81, 0.82);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        background-color 0.25s ease;
    }

    .store-badge:hover {
      background: #111;
      box-shadow: 0 18px 34px -18px rgba(21, 32, 81, 0.72);
      transform: translateY(-2px);
    }

    .store-badge:focus-visible {
      outline: 3px solid rgba(254, 254, 254, 0.85);
      outline-offset: 4px;
    }

    .store-icon {
      width: 1.75rem;
      height: 1.75rem;
      flex-shrink: 0;
    }

    .store-label {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .store-eyebrow {
      font-size: 9px;
      font-weight: 500;
      line-height: 1;
      letter-spacing: 0.01em;
    }

    .store-eyebrow-uppercase {
      text-transform: uppercase;
    }

    .store-name {
      font-size: 17px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .store-name-google {
      font-size: 16px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .map-wrap {
      filter: drop-shadow(-34px 36px 70px rgba(21, 32, 81, 0.14));
    }

    .map-mask {
      -webkit-mask-image: none;
              mask-image: none;
    }

    .map-glass::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 44% 48%, rgba(254, 254, 254, 0.14), transparent 28%),
        linear-gradient(to left, rgba(254, 254, 254, 0.06), transparent 42%);
    }

    @media (max-width: 767px) {
      .map-wrap {
        filter: none;
      }

      .map-glass::after {
        background:
          linear-gradient(to bottom, rgba(120, 195, 234, 0.02), rgba(120, 195, 234, 0.18) 58%, rgba(120, 195, 234, 0.30)),
          radial-gradient(circle at 50% 24%, rgba(254, 254, 254, 0.12), transparent 32%);
      }
    }

    @media (min-width: 640px) {
      .landing {
        padding-inline: 2rem;
      }

      .store-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .store-badge {
        padding-inline: 1rem;
      }
    }

    @media (min-width: 768px) {
      .map-wrap {
        transform: translateX(8%) scale(1.1);
      }

      .map-fade {
        width: 60%;
        background: linear-gradient(
          to right,
          rgba(120, 195, 234, 1),
          rgba(120, 195, 234, 0.88),
          rgba(120, 195, 234, 0)
        );
      }

      .logo {
        width: 5rem;
        height: 5rem;
      }

      .hero {
        align-items: center;
        padding-block: 0;
      }
    }

    @media (min-width: 1024px) {
      .landing {
        padding-inline: 3.5rem;
      }
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(14px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .rise {
      animation: rise 0.7s ease-out both;
    }

    .delay-1 {
      animation-delay: 0.05s;
    }

    .delay-2 {
      animation-delay: 0.20s;
    }

    .delay-3 {
      animation-delay: 0.35s;
    }

    .delay-4 {
      animation-delay: 0.50s;
    }

    .delay-5 {
      animation-delay: 0.65s;
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>

