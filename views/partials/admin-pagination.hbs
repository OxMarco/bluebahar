<div class="flex items-center justify-between text-xs text-ink/70 mt-4">
  <div>
    Showing {{pagination.offset}}–{{add pagination.offset pagination.shown}} (page size {{pagination.limit}})
  </div>
  <div class="flex gap-2">
    {{#if pagination.hasPrev}}
      <a href="{{pagination.prevHref}}" class="page-link">Previous</a>
    {{else}}
      <span class="page-link-muted">Previous</span>
    {{/if}}
    {{#if pagination.hasMore}}
      <a href="{{pagination.nextHref}}" class="page-link">Next</a>
    {{else}}
      <span class="page-link-muted">Next</span>
    {{/if}}
  </div>
</div>
