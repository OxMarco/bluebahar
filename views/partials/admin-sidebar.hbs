{{!-- Mobile navigation: fixed top bar + slide-over drawer. Hidden at md+, where
      the static sidebar below takes over. Uses the Alpine.js already loaded in
      admin-head. x-cloak (styled in admin.css) hides the drawer until Alpine
      initialises so there's no flash of an open menu on load. --}}
<div x-data="{ open: false }" class="md:hidden" @keydown.escape.window="open = false">
  <div class="fixed top-0 inset-x-0 z-[1000] h-14 bg-ink text-paper flex items-center justify-between px-4 shadow-sm">
    <div class="flex items-center gap-2">
      <img src="/logo.png" alt="" class="h-8 w-8 rounded-lg" />
      <span class="h-display font-semibold">BlueBaħar</span>
    </div>
    <button type="button" @click="open = true" aria-label="Open menu" class="p-2 -mr-2 rounded-md hover:bg-white/10">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <div x-show="open" x-cloak x-transition.opacity.duration.200ms @click="open = false" class="fixed inset-0 z-[1100] bg-black/40"></div>

  <aside
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed top-0 left-0 z-[1200] h-full w-64 max-w-[80%] bg-ink text-paper flex flex-col shadow-xl"
  >
    <div class="px-6 py-5 flex items-center justify-between border-b border-white/10">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="" class="h-9 w-9 rounded-lg" />
        <div>
          <div class="font-display font-semibold leading-none">BlueBaħar</div>
          <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">Admin</div>
        </div>
      </div>
      <button type="button" @click="open = false" aria-label="Close menu" class="p-2 -mr-2 rounded-md hover:bg-white/10">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>
    <nav class="flex-1 p-3 space-y-1 text-sm overflow-y-auto" @click="open = false">
      {{> admin-nav-links}}
    </nav>
    <form method="post" action="/admin/logout" class="p-3 border-t border-white/10">
      <button type="submit" class="w-full text-left text-sm text-white/70 hover:text-white px-3 py-2 rounded-md hover:bg-white/10">Sign out</button>
    </form>
  </aside>
</div>

{{!-- Static sidebar for md+ screens (unchanged layout). --}}
<aside class="hidden md:flex md:flex-col md:w-56 md:shrink-0 bg-ink text-paper">
  <div class="px-6 py-5 flex items-center gap-3 border-b border-white/10">
    <img src="/logo.png" alt="" class="h-9 w-9 rounded-lg" />
    <div>
      <div class="font-display font-semibold leading-none">BlueBaħar</div>
      <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">Admin</div>
    </div>
  </div>
  <nav class="flex-1 p-3 space-y-1 text-sm">
    {{> admin-nav-links}}
  </nav>
  <form method="post" action="/admin/logout" class="p-3 border-t border-white/10">
    <button type="submit" class="w-full text-left text-sm text-white/70 hover:text-white px-3 py-2 rounded-md hover:bg-white/10">Sign out</button>
  </form>
</aside>
