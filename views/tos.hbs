        <p class="text-ink/80">
          Questions about these terms? Write to info_AT_bluebahar_DOT_com.
        </p>
      </section>
    </main>

    <footer class="mt-8 flex flex-col items-center gap-2 text-sm text-paper/85 sm:flex-row sm:justify-between">
      <a href="/" class="font-display font-medium underline-offset-4 hover:underline">← Back to BlueBaħar</a>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="font-display font-medium underline-offset-4 hover:underline">Privacy Policy</a>
        <span class="text-paper/65">© 2026 Impossible Labs</span>
