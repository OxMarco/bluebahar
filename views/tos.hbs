  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="canonical" href="https://bluebahar.com/tos" />

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Montserrat:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sky: '#78C3EA',
            ink: '#152051',
            paper: '#FEFEFE',
            good: '#5C946E',
            warning: '#FFC857',
            bad: '#D80C2B',
          },
          fontFamily: {
            display: ['Montserrat', 'sans-serif'],
            body: ['Roboto', 'sans-serif'],
            brand: ['Fredoka', 'sans-serif'],
          },
          boxShadow: {
            soft: '0 24px 80px -36px rgba(21, 32, 81, 0.55)',
            glow: '0 18px 50px -28px rgba(255, 255, 255, 0.95)',
          },
        },
      },
    };
  </script>

  <style>
    :root {
      --ink: #152051;
      --sky: #78C3EA;
      --paper: #FEFEFE;
    }

    * { box-sizing: border-box; }

    html { min-height: 100%; scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      min-height: 100svh;
      color: var(--ink);
      background-color: var(--sky);
      background-image:
        radial-gradient(circle at 22% 14%, rgba(254, 254, 254, 0.45) 0, rgba(254, 254, 254, 0) 28%),
        radial-gradient(circle at 82% 76%, rgba(21, 32, 81, 0.10) 0, rgba(21, 32, 81, 0) 30%),
        radial-gradient(circle, rgba(21, 32, 81, 0.055) 0.5px, transparent 0.6px);
      background-size: auto, auto, 6px 6px;
      font-family: 'Roboto', sans-serif;
      text-rendering: geometricPrecision;
      -webkit-font-smoothing: antialiased;
    }

    .doc {
      background-color: rgba(254, 254, 254, 0.92);
      backdrop-filter: blur(4px);
      box-shadow: 0 24px 80px -36px rgba(21, 32, 81, 0.55);
    }

    .doc h2 {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .doc p, .doc li { line-height: 1.7; }

    .doc a {
      color: #152051;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1.5px;
    }

    .doc a:hover { text-decoration-thickness: 2.5px; }

    .accent-line {
      width: clamp(48px, 10vw, 100px);
      height: 3px;
      border-radius: 999px;
      background: linear-gradient(90deg, #152051 0%, rgba(21, 32, 81, 0.28) 100%);
    }

    .callout {
      border-left: 4px solid #D80C2B;
      background: rgba(216, 12, 43, 0.06);
    }
  </style>
</head>

