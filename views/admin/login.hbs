<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign in · BlueBaħar admin</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="min-h-screen bg-[#152051] text-white flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="flex items-center gap-3 mb-8">
      <img src="/logo.png" alt="" class="h-12 w-12 rounded-xl" />
      <div>
        <div class="h-display font-semibold text-lg leading-none">BlueBaħar</div>
        <div class="text-[11px] uppercase tracking-widest text-white/55 mt-1">Admin panel</div>
      </div>
    </div>
    <form method="post" action="/admin/login" class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
      {{#if notice}}
        <p class="rounded-md border border-warning/30 bg-warning/10 text-warning text-xs px-3 py-2 mb-4">{{notice}}</p>
      {{/if}}
      <label class="block text-xs uppercase tracking-widest text-white/60 mb-2" for="key">Admin key</label>
      <input
        id="key"
        name="key"
        type="password"
        autocomplete="current-password"
        required
        autofocus
        class="w-full bg-black/30 border border-white/15 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-white/50"
      />
      {{#if error}}
        <p class="text-bad text-xs mt-2">{{error}}</p>
      {{/if}}
      <button
        type="submit"
        class="mt-4 w-full bg-white text-ink font-medium rounded-md py-2 hover:bg-white/90 transition"
      >Sign in</button>
    </form>
  </div>
</body>
</html>
