<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="page-header">
        <div>
          <h1 class="page-title">{{title}}</h1>
          <p class="page-subtitle">Reports submitted by boaters against a point on the map. Newest first.</p>
        </div>
        <div class="flex items-center gap-1 text-sm bg-ink/5 rounded-lg p-1">
          <a href="/admin/reports" class="px-3 py-1 rounded-md {{#unless resolved}}bg-white font-medium{{else}}text-ink/60{{/unless}}">Open</a>
          <a href="/admin/reports?resolved=true" class="px-3 py-1 rounded-md {{#if resolved}}bg-white font-medium{{else}}text-ink/60{{/if}}">Resolved</a>
        </div>
      </header>

      {{#if reports.length}}
        <div class="table-wrap">
          <table class="min-w-full text-sm cards-sm">
            <thead class="table-head">
              <tr>
                <th class="px-4 py-3">Report</th>
                <th class="px-4 py-3">Location</th>
                <th class="px-4 py-3">Submitted</th>
                <th class="px-4 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="table-body">
              {{#each reports}}
                <tr id="row-{{this.id}}">
                  <td class="px-4 py-3 align-top" data-label="Report">
                    <div class="font-medium">{{this.title}}</div>
                    <div class="text-xs text-ink/55 mt-0.5">{{this.description}}</div>
                  </td>
                  <td class="px-4 py-3 align-top text-xs" data-label="Location">
                    <a
                      href="https://www.openstreetmap.org/?mlat={{this.latitude}}&mlon={{this.longitude}}#map=14/{{this.latitude}}/{{this.longitude}}"
                      target="_blank"
                      rel="noopener"
                      class="text-ink/70 hover:underline"
                    >{{this.latitude}}, {{this.longitude}}</a>
                  </td>
                  <td class="px-4 py-3 align-top text-xs" data-label="Submitted">{{formatDate this.createdAt}}</td>
                  <td class="px-4 py-3 align-top" data-label="Actions">
                    <div class="row-actions flex gap-2 justify-end">
                      {{#unless this.resolved}}
                        <button
                          hx-post="/admin/reports/{{this.id}}/resolve"
                          hx-target="#row-{{this.id}}"
                          hx-swap="outerHTML"
                          class="btn btn-sm btn-good"
                          data-toast="Report resolved"
                        >Resolve</button>
                      {{/unless}}
                      <button
                        hx-delete="/admin/reports/{{this.id}}"
                        hx-target="#row-{{this.id}}"
                        hx-swap="outerHTML"
                        hx-confirm="Permanently delete this report?"
                        class="btn btn-sm btn-danger"
                        data-toast="Report deleted"
                      >Delete</button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{> admin-pagination}}
      {{else}}
        <div class="empty-state">
          {{#if resolved}}No resolved reports.{{else}}No open reports.{{/if}}
        </div>
      {{/if}}
    </main>
  </div>
</body>
</html>
