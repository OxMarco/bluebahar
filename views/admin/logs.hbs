<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="page-header">
        <div>
          <h1 class="page-title">{{title}}</h1>
          <p class="page-subtitle">Scraping and ingestion activity, newest first.</p>
        </div>
        <form method="get" class="filter-form">
          <label for="logType" class="text-ink/60">Type</label>
          <select name="logType" id="logType" class="field-input-sm bg-white">
            <option value="">All</option>
            {{#each logTypes}}
              <option value="{{this}}" {{#if (eq this ../selectedLogType)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
          <button type="submit" class="btn btn-primary px-3 py-1">Filter</button>
        </form>
      </header>

      {{#if logs.length}}
        <div class="table-wrap">
          <table class="min-w-full text-sm cards-sm">
            <thead class="table-head">
              <tr>
                <th class="px-4 py-3 w-44">When</th>
                <th class="px-4 py-3 w-48">Type</th>
                <th class="px-4 py-3">Description</th>
              </tr>
            </thead>
            <tbody class="table-body">
              {{#each logs}}
                <tr>
                  <td class="px-4 py-3 align-top text-xs text-ink/70 w-44" data-label="When">
                    <div class="whitespace-nowrap">{{formatDate this.createdAt}}</div>
                    <div class="text-ink/40">{{formatRelative this.createdAt}}</div>
                  </td>
                  <td class="px-4 py-3 align-top" data-label="Type"><span class="badge">{{this.logType}}</span></td>
                  <td class="px-4 py-3 align-top text-sm" data-label="Description">{{this.description}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{> admin-pagination}}
      {{else}}
        <div class="empty-state">
          No log entries.
        </div>
      {{/if}}
    </main>
  </div>
</body>
</html>
