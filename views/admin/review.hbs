<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="mb-6">
        <h1 class="page-title">{{title}}</h1>
        <p class="page-subtitle">Notices the extractor flagged for manual review. Click a row to inspect the area. Approve to publish, reject to delete.</p>
      </header>

      {{#if notices.length}}
        <div class="review-layout">
          <div class="table-wrap">
            <table class="min-w-full text-sm cards-sm">
              <thead class="table-head">
                <tr>
                  <th class="px-4 py-3">Title</th>
                  <th class="px-4 py-3">Kind</th>
                  <th class="px-4 py-3">Active</th>
                  <th class="px-4 py-3">Source</th>
                  <th class="px-4 py-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="table-body">
                {{#each notices}}
                  <tr id="row-{{this.id}}" class="review-row" data-notice-id="{{this.id}}">
                    <td class="px-4 py-3 align-top" data-label="Notice">
                      <div class="font-medium notice-title">{{this.title}}</div>
                      <div class="text-xs text-ink/55 mt-0.5 line-clamp-2">{{this.description}}</div>
                      {{#if this.reviewReasons.length}}
                        <ul class="mt-2 space-y-1 text-[11px] text-warning">
                          {{#each this.reviewReasons}}
                            <li class="break-words">{{this}}</li>
                          {{/each}}
                        </ul>
                      {{/if}}
                      {{#if this.locationLabel}}
                        <div class="text-[11px] text-ink/45 mt-1">{{this.locationLabel}}</div>
                      {{/if}}
                      <script type="application/json" id="geom-{{this.id}}">{{{json this.geometry}}}</script>
                      <script type="application/json" id="reps-{{this.id}}">{{{json this.representativePoints}}}</script>
                    </td>
                    <td class="px-4 py-3 align-top" data-label="Kind"><span class="badge">{{this.kind}}</span></td>
                    <td class="px-4 py-3 align-top text-xs" data-label="Active">
                      <div>{{formatDate this.activeFrom}}</div>
                      {{#if this.activeTo}}<div class="text-ink/50">→ {{formatDate this.activeTo}}</div>{{else}}<div class="text-ink/50">→ no expiry</div>{{/if}}
                    </td>
                    <td class="px-4 py-3 align-top text-xs" data-label="Source">
                      <a href="{{this.source}}" target="_blank" rel="noopener" class="text-ink/70 hover:underline break-all">{{this.source}}</a>
                    </td>
                    <td class="px-4 py-3 align-top" data-label="Actions">
                      <div class="row-actions flex gap-2 justify-end">
                        <button
                          hx-post="/admin/notices/{{this.id}}/approve"
                          hx-target="#row-{{this.id}}"
                          hx-swap="outerHTML"
                          class="btn btn-sm btn-good"
                          data-toast="Notice approved"
                        >Approve</button>
                        <button
                          hx-delete="/admin/notices/{{this.id}}"
                          hx-target="#row-{{this.id}}"
                          hx-swap="outerHTML"
                          hx-confirm="Permanently delete this notice?"
                          class="btn btn-sm btn-danger"
                          data-toast="Notice rejected"
                        >Reject</button>
                      </div>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
          <aside class="review-map-panel">
            <div id="review-map" class="review-map"></div>
            <p id="review-map-hint" class="text-xs text-ink/55 mt-2">Click a row to view its area on the map.</p>
          </aside>
        </div>
        {{> admin-pagination}}
      {{else}}
        <div class="empty-state">
          Nothing to review.
        </div>
      {{/if}}
    </main>
  </div>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <script src="/admin-review-map.js" defer></script>
</body>
</html>
