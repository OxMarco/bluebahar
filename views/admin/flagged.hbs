<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="flex-1 p-6 md:p-10">
      <header class="mb-6 flex items-end justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-2xl font-display font-semibold">{{title}}</h1>
          <p class="text-sm text-ink/60 mt-1">Notices reported as inaccurate by users. Sorted by report count, descending.</p>
        </div>
        <form method="get" class="flex items-center gap-2 text-sm">
          <label for="minReports" class="text-ink/60">Min reports</label>
          <input type="number" min="1" name="minReports" id="minReports" value="{{minReports}}" class="w-20 border border-ink/15 rounded-md px-2 py-1" />
          <button type="submit" class="px-3 py-1 bg-ink text-white rounded-md hover:opacity-90">Filter</button>
        </form>
      </header>

      {{#if notices.length}}
        <div class="overflow-x-auto border border-ink/10 rounded-xl bg-white">
          <table class="min-w-full text-sm">
            <thead class="text-left text-xs uppercase tracking-wider text-ink/55 border-b border-ink/10">
              <tr>
                <th class="px-4 py-3">Title</th>
                <th class="px-4 py-3">Kind</th>
                <th class="px-4 py-3">Active</th>
                <th class="px-4 py-3">Source</th>
                <th class="px-4 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink/5">
              {{#each notices}}
                <tr id="row-{{this.id}}">
                  <td class="px-4 py-3 align-top">
                    <div class="flex items-center gap-2">
                      <span class="font-medium">{{this.title}}</span>
                      <span class="text-[11px] font-semibold bg-bad/10 text-bad rounded-full px-2 py-0.5" title="user reports">{{this.reports}}</span>
                    </div>
                    <div class="text-xs text-ink/55 mt-0.5 line-clamp-2">{{this.description}}</div>
                    {{#if this.locationLabel}}
                      <div class="text-[11px] text-ink/45 mt-1">{{this.locationLabel}}</div>
                    {{/if}}
                  </td>
                  <td class="px-4 py-3 align-top"><span class="inline-block text-[11px] uppercase tracking-wider bg-ink/5 rounded px-2 py-0.5">{{this.kind}}</span></td>
                  <td class="px-4 py-3 align-top text-xs">
                    <div>{{formatDate this.activeFrom}}</div>
                    {{#if this.activeTo}}<div class="text-ink/50">→ {{formatDate this.activeTo}}</div>{{else}}<div class="text-ink/50">→ no expiry</div>{{/if}}
                  </td>
                  <td class="px-4 py-3 align-top text-xs">
                    <a href="{{this.source}}" target="_blank" rel="noopener" class="text-ink/70 hover:underline break-all">{{this.source}}</a>
                  </td>
                  <td class="px-4 py-3 align-top">
                    <div class="row-actions flex gap-2 justify-end">
                      <button
                        hx-post="/admin/notices/{{this.id}}/dismiss-reports"
                        hx-target="#row-{{this.id}}"
                        hx-swap="outerHTML"
                        class="text-xs bg-warning text-ink rounded-md px-3 py-1.5 hover:opacity-90"
                      >Dismiss reports</button>
                      <button
                        hx-delete="/admin/notices/{{this.id}}"
                        hx-target="#row-{{this.id}}"
                        hx-swap="outerHTML"
                        hx-confirm="Permanently delete this notice?"
                        class="text-xs bg-bad text-white rounded-md px-3 py-1.5 hover:opacity-90"
                      >Delete</button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{> admin-pagination}}
      {{else}}
        <div class="border border-ink/10 rounded-xl bg-white p-10 text-center text-ink/60">
          No notices with ≥ {{minReports}} report(s).
        </div>
      {{/if}}
    </main>
  </div>
</body>
</html>
