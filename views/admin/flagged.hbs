<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="page-header">
        <div>
          <h1 class="page-title">{{title}}</h1>
          <p class="page-subtitle">Notices reported as inaccurate by users. Sorted by report count, descending.</p>
        </div>
        <form method="get" class="filter-form">
          <label for="minReports" class="text-ink/60">Min reports</label>
          <input type="number" min="1" name="minReports" id="minReports" value="{{minReports}}" class="w-20 field-input-sm" />
          <button type="submit" class="btn btn-primary px-3 py-1">Filter</button>
        </form>
      </header>

      {{#if notices.length}}
        <div class="table-wrap">
          <table class="min-w-full text-sm cards-sm">
            <thead class="table-head">
              <tr>
                <th class="px-4 py-3">Title</th>
                <th class="px-4 py-3">Kind</th>
                <th class="px-4 py-3">Active</th>
                <th class="px-4 py-3">Source</th>
                <th class="px-4 py-3 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="table-body">
              {{#each notices}}
                <tr id="row-{{this.id}}">
                  <td class="px-4 py-3 align-top" data-label="Notice">
                    <div class="flex items-center gap-2">
                      <span class="font-medium">{{this.title}}</span>
                      <span class="text-[11px] font-semibold bg-bad/10 text-bad rounded-full px-2 py-0.5" title="user reports">{{this.reports}}</span>
                    </div>
                    <div class="text-xs text-ink/55 mt-0.5 line-clamp-2">{{this.description}}</div>
                    {{#if this.locationLabel}}
                      <div class="text-[11px] text-ink/45 mt-1">{{this.locationLabel}}</div>
                    {{/if}}
                  </td>
                  <td class="px-4 py-3 align-top" data-label="Kind"><span class="badge">{{this.kind}}</span></td>
                  <td class="px-4 py-3 align-top text-xs" data-label="Active">
                    <div>{{formatDate this.activeFrom}}</div>
                    {{#if this.activeTo}}<div class="text-ink/50">→ {{formatDate this.activeTo}}</div>{{else}}<div class="text-ink/50">→ no expiry</div>{{/if}}
                  </td>
                  <td class="px-4 py-3 align-top text-xs" data-label="Source">
                    <a href="{{this.source}}" target="_blank" rel="noopener" class="text-ink/70 hover:underline break-all">{{this.source}}</a>
                  </td>
                  <td class="px-4 py-3 align-top" data-label="Actions">
                    <div class="row-actions flex gap-2 justify-end">
                      <button
                        hx-post="/admin/notices/{{this.id}}/dismiss-reports"
                        hx-target="#row-{{this.id}}"
                        hx-swap="outerHTML"
                        class="btn btn-sm btn-warning"
                        data-toast="Reports dismissed"
                      >Dismiss reports</button>
                      <button
                        hx-delete="/admin/notices/{{this.id}}"
                        hx-target="#row-{{this.id}}"
                        hx-swap="outerHTML"
                        hx-confirm="Permanently delete this notice?"
                        class="btn btn-sm btn-danger"
                        data-toast="Notice deleted"
                      >Delete</button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{> admin-pagination}}
      {{else}}
        <div class="empty-state">
          No notices with ≥ {{minReports}} report(s).
        </div>
      {{/if}}
    </main>
  </div>
</body>
</html>
