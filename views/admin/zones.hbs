<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="mb-4">
        <h1 class="page-title">{{title}}</h1>
        <p class="page-subtitle">
          Every notice with geometry, drawn on one map.
          <strong>{{total}}</strong> zone(s):
          <strong>{{communityCount}}</strong> from the community map,
          <strong>{{otherCount}}</strong> created manually.
          Click a shape for details.
        </p>
      </header>

      {{#if total}}
        <div class="layer-toolbar mb-3">
          <div class="layer-group">
            <span class="layer-group-label">Notices</span>
            <button type="button" class="layer-toggle" data-notice-layer="notices" data-color="#152051" aria-pressed="true">
              <i class="layer-swatch"></i> Notices
            </button>
            <button type="button" class="layer-toggle" data-notice-layer="review" data-color="#b45309" data-style="ring" aria-pressed="true">
              <i class="layer-swatch"></i> Needs review
            </button>
          </div>
          <div class="layer-group" id="dataset-toggles" hidden>
            <span class="layer-group-label">Reference layers</span>
            {{!-- dataset toggles are injected by admin-zones-map.js --}}
          </div>
        </div>
        <div id="zones-map" class="zones-map"></div>
        <script type="application/json" id="zones-data">{{{json featureCollection}}}</script>
      {{else}}
        <div class="empty-state">
          No zones with geometry yet. If the community-map import just ran, give it a moment and refresh.
        </div>
      {{/if}}
    </main>
  </div>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <script src="/admin-zones-map.js" defer></script>
</body>
</html>
