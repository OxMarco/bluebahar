<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="flex-1 p-6 md:p-10">
      <header class="mb-4">
        <h1 class="text-2xl font-display font-semibold">{{title}}</h1>
        <p class="text-sm text-ink/60 mt-1">
          Every notice with geometry, drawn on one map.
          <strong>{{total}}</strong> zone(s):
          <strong>{{communityCount}}</strong> from the community map,
          <strong>{{otherCount}}</strong> created manually.
          Click a shape for details.
        </p>
      </header>

      {{#if total}}
        <div class="zones-legend mb-3">
          <span><i class="zones-swatch" style="background:#0e7490"></i> Community map</span>
          <span><i class="zones-swatch" style="background:#152051"></i> Manual</span>
          <span><i class="zones-swatch" style="background:#b45309"></i> Needs review</span>
        </div>
        <div id="zones-map" class="zones-map"></div>
        <script type="application/json" id="zones-data">{{{json featureCollection}}}</script>
      {{else}}
        <div class="border border-ink/10 rounded-xl bg-white p-10 text-center text-ink/60">
          No zones with geometry yet. If the community-map import just ran, give it a moment and refresh.
        </div>
      {{/if}}
    </main>
  </div>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <script src="/admin-zones-map.js" defer></script>
</body>
</html>
