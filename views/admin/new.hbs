<!DOCTYPE html>
<html lang="en">
<head>
  {{> admin-head}}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body class="bg-paper text-ink">
  <div class="min-h-screen flex">
    {{> admin-sidebar}}
    <main class="admin-main">
      <header class="mb-6">
        <h1 class="page-title">{{title}}</h1>
        <p class="page-subtitle">Manually add a notice. Skips the extraction review queue.</p>
      </header>

      {{#if success}}
        <div class="alert alert-good mb-4 px-4 py-2 text-sm">{{success}}</div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-bad mb-4 px-4 py-2 text-sm">{{error}}</div>
      {{/if}}

      <form
        method="post"
        action="/admin/notices"
        enctype="application/x-www-form-urlencoded"
        class="bg-white border border-ink/10 rounded-xl shadow-sm p-6 max-w-3xl grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm"
      >
        <label class="flex flex-col gap-1">
          <span class="field-label">Kind</span>
          <select name="kind" required class="field-input bg-white">
            {{#each kinds}}
              <option value="{{this}}" {{#if (eq this ../form.kind)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Source URL</span>
          <input type="url" name="source" required value="{{form.source}}" class="field-input" placeholder="https://..." />
        </label>

        <label class="flex flex-col gap-1 sm:col-span-2">
          <span class="field-label">Title</span>
          <input type="text" name="title" required value="{{form.title}}" class="field-input" />
        </label>

        <label class="flex flex-col gap-1 sm:col-span-2">
          <span class="field-label">Description</span>
          <textarea name="description" required rows="4" class="field-input">{{form.description}}</textarea>
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Location label</span>
          <input type="text" name="locationLabel" value="{{form.locationLabel}}" class="field-input" placeholder="optional" />
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Sub-key</span>
          <input type="text" name="subKey" value="{{form.subKey}}" class="field-input" placeholder="optional, for source de-dup" />
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Published at</span>
          <input type="datetime-local" name="publishedAt" required value="{{datetimeLocal form.publishedAt}}" class="field-input" />
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Active from</span>
          <input type="datetime-local" name="activeFrom" required value="{{datetimeLocal form.activeFrom}}" class="field-input" />
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Active to</span>
          <input type="datetime-local" name="activeTo" value="{{datetimeLocal form.activeTo}}" class="field-input" />
        </label>

        <label class="flex flex-col gap-1">
          <span class="field-label">Safety distance (m)</span>
          <input type="number" min="0" step="any" name="distance" value="{{form.distance}}" class="field-input" />
        </label>

        <div class="sm:col-span-2 flex flex-col gap-3 border-t border-ink/10 pt-4 mt-1">
          <div class="flex items-center justify-between gap-2">
            <div>
              <span class="field-label">Geometries</span>
              <p class="text-xs text-ink/55 mt-1">Add one or more areas. Each can be a point, line, or polygon. Pick a part, then click the map to drop points, or type coordinates directly.</p>
            </div>
            <button type="button" id="geometry-add-part" class="btn btn-sm btn-primary whitespace-nowrap">Add geometry part</button>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 items-start">
            <div id="geometry-parts" class="geometry-parts"></div>
            <div>
              <div id="geometry-map" class="geometry-map"></div>
              <p id="geometry-map-hint" class="text-xs text-ink/55 mt-2">Add a geometry part to start drawing.</p>
            </div>
          </div>

          <p id="geometry-empty" class="text-xs text-ink/55">No geometries added — this notice will have no location on the map.</p>

          <input type="hidden" name="areas" id="areas-input" />
          <script type="application/json" id="initial-areas">{{{json form.areas}}}</script>
        </div>

        <div class="sm:col-span-2 flex justify-end gap-2 pt-2">
          <a href="/admin/review" class="text-sm text-ink/60 hover:text-ink px-4 py-2">Cancel</a>
          <button type="submit" class="btn btn-primary text-sm px-4 py-2">Create</button>
        </div>
      </form>
    </main>
  </div>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>
  <script src="/admin-new-geometry.js" defer></script>
</body>
</html>
